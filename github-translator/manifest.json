{
  "manifest_version": 3,
  "name": "GitHub 局部翻译工具",
  "version": "1.1",
  "description": "GitHub 中文提示插件",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["Language/*.json"],
      "matches": ["https://github.com/*"]
    }
  ]
}